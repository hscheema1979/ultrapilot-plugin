# Ultrapilot Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Anthropic Claude API
# ============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom API base URL (for proxy/testing)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Request timeout in milliseconds (default: 60000)
# ANTHROPIC_TIMEOUT=60000

# ============================================================================
# OPTIONAL: GitHub Integration
# ============================================================================

# GitHub Personal Access Token (for GitHub API operations)
# Get one from: https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_token_here

# GitHub App credentials (for GitHub App integration)
# GITHUB_APP_ID=your_app_id_here
# GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Webhook secret (for verifying GitHub webhooks)
# Generate a random string: openssl rand -base64 32
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================

# Server port (default: 3000)
# PORT=3000

# Node environment (development/production)
# NODE_ENV=development
